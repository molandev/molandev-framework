{
  "properties": [
    {
      "name": "molandev.file.type",
      "type": "com.molandev.framework.file.config.FileProperties$StorageType",
      "description": "文件存储类型：local（本地存储）、s3（S3对象存储）",
      "defaultValue": "local"
    },
    {
      "name": "molandev.file.default-bucket",
      "type": "java.lang.String",
      "description": "默认bucket名称",
      "defaultValue": "default"
    },
    {
      "name": "molandev.file.local.base-path",
      "type": "java.lang.String",
      "description": "本地存储根路径",
      "defaultValue": "./files"
    },
    {
      "name": "molandev.file.s3.endpoint",
      "type": "java.lang.String",
      "description": "S3服务端点（如：https://s3.amazonaws.com）"
    },
    {
      "name": "molandev.file.s3.region",
      "type": "java.lang.String",
      "description": "S3区域（如：us-east-1）",
      "defaultValue": "us-east-1"
    },
    {
      "name": "molandev.file.s3.access-key",
      "type": "java.lang.String",
      "description": "S3访问密钥"
    },
    {
      "name": "molandev.file.s3.secret-key",
      "type": "java.lang.String",
      "description": "S3秘密密钥"
    },
    {
      "name": "molandev.file.s3.bucket",
      "type": "java.lang.String",
      "description": "S3默认bucket名称"
    },
    {
      "name": "molandev.file.s3.path-style-access",
      "type": "java.lang.Boolean",
      "description": "是否使用路径风格访问（兼容某些S3实现）",
      "defaultValue": false
    }
  ]
}
